{
  "name": "run-the-ai-play",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "pages:build": "prisma generate && npx @cloudflare/next-on-pages@1",
    "pages:dev": "wrangler pages dev .vercel/output/static --d1 DB=runtheaiplay-db",
    "pages:schema:apply": "wrangler d1 execute runtheaiplay-db --file=./prisma/schema.sql --remote",
    "pages:schema:apply:local": "wrangler d1 execute runtheaiplay-db --file=./prisma/schema.sql --local",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-d1": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.460.0",
    "next": "^14.2.34",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.12.2",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260426.1",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.184.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vercel": "^52.0.0",
    "wrangler": "^4.85.0"
  }
}
